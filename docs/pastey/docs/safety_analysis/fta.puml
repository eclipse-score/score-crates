@startuml pastey_fta

title Fault Tree Analysis - pastey paste! macro failure

rectangle "Top Event\nIncorrect or missing identifier\nin generated Rust code" as top #pink

rectangle "OR" as or1

rectangle "Empty token stream\npassed to paste!" as leaf1 #lightyellow
rectangle "paste! used in\ninvalid syntax position" as leaf2 #lightyellow

top --> or1
or1 --> leaf1
or1 --> leaf2

@enduml